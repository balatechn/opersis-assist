# ============================================================================
# Opersis Assist — Production Environment Variables
# Copy to .env and fill in all values before deployment
# ============================================================================

# ── Database ──
MONGO_PASSWORD=<generate: openssl rand -base64 32>

# ── Secrets ──
JWT_SECRET=<generate: openssl rand -hex 32>
AGENT_SECRET=<generate: openssl rand -hex 32>

# ── URLs (replace with your domain or IP) ──
# If using Coolify with a domain:
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com
#   NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com
# If using IP directly:
NEXT_PUBLIC_API_URL=http://187.127.134.246:4000
NEXT_PUBLIC_WS_URL=ws://187.127.134.246:4000
CORS_ORIGIN=http://187.127.134.246:3000,http://187.127.134.246:8000

# ── Ports ──
BACKEND_PORT=4000
FRONTEND_PORT=3000

# ── Admin seed (first boot only) ──
ADMIN_EMAIL=bpillai100@gmail.com
ADMIN_PASSWORD=<set-a-strong-password>
ADMIN_NAME=Super Admin

# ── Logging ──
LOG_LEVEL=info
