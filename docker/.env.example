# ── Opersis Assist — Environment Configuration ──

# MongoDB
MONGO_PASSWORD=change-this-strong-password

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-string-at-least-64-chars

# Agent Secret (must match agent .env)
AGENT_SECRET=change-this-agent-secret-key-at-least-64-chars

# External URLs (change for production domain)
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com
CORS_ORIGIN=https://your-domain.com

# Ports
BACKEND_PORT=4000
FRONTEND_PORT=3000

# Logging
LOG_LEVEL=info
