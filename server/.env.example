# ── Opersis Assist Server Configuration ──

# Server
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://opersis:changeme@localhost:27017/opersis-assist?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-long-random-string-64-chars-minimum
JWT_EXPIRES_IN=24h

# Agent
AGENT_SECRET=change-this-agent-secret-key-64-chars-minimum

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
